# ============================================
# AegisFlowAI Environment Variables
# ============================================

# === Database (PostgreSQL + PostGIS) ===
DB_DATABASE=aegisflow
DB_USERNAME=aegisflow
DB_PASSWORD=secret

# === Mapbox ===
MAPBOX_TOKEN=pk.your_mapbox_token_here

# === Soketi / Pusher (WebSocket) ===
PUSHER_APP_KEY=aegisflow-key
PUSHER_APP_SECRET=aegisflow-secret

# === AI Service ===
AI_SERVICE_KEY=internal-service-key

# === External APIs (Optional) ===
OPENWEATHER_API_KEY=
GOOGLE_MAPS_API_KEY=
